                    <td className="px-4 py-3 text-right text-[#f1f5f9]">{profit !== 0 ? formatProfitDisplay(profit, allArbs) : "—"}</td>
                    <td className="px-4 py-3"><StrategyBadge strategy={strategy} /></td>
                    <td className="px-4 py-3 text-center">
                      <button
