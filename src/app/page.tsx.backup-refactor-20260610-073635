}

/* ── Market Sidebar ── */
function MarketSidebar({
  markets,
  activeId,
  viewMode,
  onSelectMarket,
  onEditMarket,
  onDeleteMarket,
  onRefreshSingle,
  scanningIds,
  sort,
  sortDir,
  onToggleSort,
  timeUntilExpiry,
  layout,
  onToggleLayout,
  expiryFilter,
  onSetExpiryFilter,
  onScanAll,
  scanningAll,
  scanAllError,
  favoriteIds,
  onToggleFavorite,
  showFavoritesOnly,
  onToggleFavoritesOnly,
}: {
  markets: SavedMarket[];
  activeId: string | null;
  viewMode: string;
  onSelectMarket: (m: SavedMarket) => void;
  onEditMarket: (m: SavedMarket) => void;
  onDeleteMarket: (id: string) => void;
  onRefreshSingle: (m: SavedMarket) => void;
  scanningIds: Set<string>;
  sort: SidebarSort;
  sortDir: "asc" | "desc";
  onToggleSort: (f: SidebarSort) => void;
  timeUntilExpiry: (iso?: string | null) => string;
  layout: "grid" | "table";
  onToggleLayout: (l: "grid" | "table") => void;
  expiryFilter: "all" | "lte7" | "lte14" | "lte30";
  onSetExpiryFilter: (f: "all" | "lte7" | "lte14" | "lte30") => void;
  onScanAll: () => void;
  scanningAll: boolean;
  scanAllError: string;
  favoriteIds: Set<string>;
  onToggleFavorite: (id: string) => void;
  showFavoritesOnly: boolean;
  onToggleFavoritesOnly: () => void;
}) {
  const [sidebarOpen, setSidebarOpen] = useState(true);
  const [sidebarSearch, setSidebarSearch] = useState("");
  const [contextMenu, setContextMenu] = useState<{x: number; y: number; market: SavedMarket} | null>(null);

  // Close context menu on click outside
  useEffect(() => {
    const close = () => setContextMenu(null);
    window.addEventListener("click", close);
    return () => window.removeEventListener("click", close);
  }, []);

  // Filter + sort
  const filtered = markets.filter(m => {
    if (showFavoritesOnly && !favoriteIds.has(m.id)) return false;
    if (expiryFilter !== "all") {
      if (!m.expiryDate) return true;
      const days = (parseDateToUTC(m.expiryDate) - Date.now()) / 86400000;
      if (expiryFilter === "lte7" && days > 7) return false;
      if (expiryFilter === "lte14" && days > 14) return false;
      if (expiryFilter === "lte30" && days > 30) return false;
    }
    if (sidebarSearch && !m.eventTitle.toLowerCase().includes(sidebarSearch.toLowerCase())) return false;
    return true;
  }).sort((a, b) => {
    const mul = sortDir === "asc" ? 1 : -1;
    if (sort === "name") return mul * a.eventTitle.localeCompare(b.eventTitle);
    if (sort === "expiry") {
      const ea = a.expiryDate ? new Date(a.expiryDate).getTime() : Infinity;
      const eb = b.expiryDate ? new Date(b.expiryDate).getTime() : Infinity;
      return mul * (ea - eb);
    }
    if (sort === "roi") {
      const ra = a.lastScanResult?.bestRoiPct ?? 0;
      const rb = b.lastScanResult?.bestRoiPct ?? 0;
      return mul * (rb - ra);
    }
    if (sort === "apy") {
      const ra = a.liveResult?.bestRoiPct ?? a.lastScanResult?.bestRoiPct ?? 0;
      const rb = b.liveResult?.bestRoiPct ?? b.lastScanResult?.bestRoiPct ?? 0;
      const aa = calculateAPY(ra, a.expiryDate);
      const ab = calculateAPY(rb, b.expiryDate);
      return mul * (ab - aa);
    }
    return 0;
  });

  return (
    <aside className={`${sidebarOpen ? "w-72" : "w-12"} shrink-0 border-r border-[#334155] bg-[#1e293b] overflow-hidden transition-all duration-200 flex flex-col relative`}>
      {sidebarOpen ? (
        <div className="p-4 space-y-4 h-full flex flex-col">
          <div className="flex items-center justify-between">
            <h2 className="text-sm font-bold text-[#f1f5f9]">Saved Markets ({markets.length})</h2>
            <div className="flex items-center gap-1">
              <button onClick={() => setSidebarOpen(false)} className="p-1.5 rounded-md hover:bg-[#334155] text-[#94a3b8] hover:text-[#f1f5f9] transition-colors" title="Collapse sidebar">
                <PanelLeftClose className="w-4 h-4" />
              </button>
              <button onClick={onToggleFavoritesOnly} className={`p-1.5 rounded-md transition-colors ${showFavoritesOnly ? "text-[#f59e0b] bg-[#f59e0b]/10" : "text-[#94a3b8] hover:bg-[#334155] hover:text-[#f59e0b]"}`} title="Toggle favorites only">
                <Star className={`w-4 h-4 ${showFavoritesOnly ? "fill-current" : ""}`} />
              </button>
              <button onClick={onScanAll} disabled={scanningAll} className="p-1.5 rounded-md hover:bg-[#334155] text-[#94a3b8] hover:text-[#10b981] transition-colors disabled:opacity-50" title="Scan All">
                {scanningAll ? <Loader2 className="w-4 h-4 animate-spin" /> : <RefreshCw className="w-4 h-4" />}
              </button>
            </div>
          </div>

          {scanAllError && <div className="text-xs text-[#ef4444]">{scanAllError}</div>}

          {/* Search + Sort */}
          <div className="space-y-2">
            <input
              type="text"
              value={sidebarSearch}
              onChange={(e) => setSidebarSearch(e.target.value)}
              placeholder="Search markets..."
              className="w-full px-2 py-1.5 rounded-md bg-[#334155] border border-[#475569] text-xs text-[#f1f5f9] placeholder-[#525252] focus:outline-none focus:border-[#10b981]"
            />
            <div className="flex items-center gap-0.5">
              {/* Sort buttons */}
              {(["apy", "roi", "name", "expiry"] as const).map((field) => (
                <button
                  key={field}
                  onClick={() => onToggleSort(field)}
                  className={`px-1.5 py-1 rounded text-[10px] font-medium transition-colors ${
                    sort === field
                      ? "bg-[#10b981]/10 text-[#10b981]"
                      : "text-[#525252] hover:text-[#64748b] hover:bg-[#334155]"
                  }`}
                  title={`Sort by ${field}`}
                >
                  {field === "apy" ? "APY" : field === "roi" ? "ROI" : field === "name" ? "Name" : "Exp"}
                  {sort === field && (sortDir === "asc" ? " ↑" : " ↓")}
                </button>
              ))}
            </div>
          </div>

        {/* Market list */}
        <div className="flex-1 overflow-y-auto space-y-1 min-h-0">
          {filtered.map((m) => {
            const roi = m.liveResult?.bestRoiPct ?? m.lastScanResult?.bestRoiPct ?? 0;
            const isActive = activeId === m.id;
            const isFav = favoriteIds.has(m.id);
            return (
              <div
                key={m.id}
                onClick={() => onSelectMarket(m)}
                onContextMenu={(e) => {
                  e.preventDefault();
                  setContextMenu({ x: e.clientX, y: e.clientY, market: m });
                }}
                className={`flex items-center gap-2 px-2 py-2 rounded-lg cursor-pointer transition-colors ${
                  isActive ? "bg-[#10b981]/10 ring-1 ring-[#10b981]/30" : "hover:bg-[#334155]"
                }`}
              >
                <button
                  onClick={(e) => {
                    e.stopPropagation();
                    onToggleFavorite(m.id);
                  }}
                  className={`shrink-0 p-0.5 rounded transition-colors ${isFav ? "text-[#f59e0b]" : "text-[#525252] hover:text-[#f59e0b]"}`}
                  title={isFav ? "Remove favorite" : "Add favorite"}
                >
                  <Star className={`w-3.5 h-3.5 ${isFav ? "fill-current" : ""}`} />
                </button>
                <div className="flex-1 min-w-0">
                  <div className="text-xs font-medium text-[#f1f5f9] truncate">{m.eventTitle}</div>
                  <div className="flex items-center gap-1.5 mt-0.5">
                    {m.category && (
                      <span className="text-[9px] px-1.5 py-0.5 rounded-full bg-[#334155] text-[#94a3b8]">{m.category}</span>
                    )}
                    <span className="text-[9px] text-[#94a3b8]">{timeUntilExpiry(m.expiryDate)}</span>
                  </div>
                </div>
                {roi !== 0 && (
                  <div className="flex flex-col items-end">
                    <span className={`text-xs font-bold ${roi > 0 ? "text-[#10b981]" : "text-[#ef4444]"}`}>
                      {roi > 0 ? "+" : ""}{formatPercent(roi)}
                    </span>
                    <span className="text-[9px] text-[#64748b]">
                      ({calculateAPY(roi, m.expiryDate).toFixed(1)}% APY)
                    </span>
                  </div>
                )}
              </div>
            );
          })}
          {filtered.length === 0 && markets.length > 0 && (
            <div className="text-xs text-[#525252] text-center py-4">No markets match filters.</div>
          )}
          {markets.length === 0 && (
            <div className="text-xs text-[#525252] text-center py-4">No saved markets yet.</div>
          )}
        </div>

        {/* Context Menu */}
        {contextMenu && (
          <div
            className="fixed z-[100] w-44 rounded-lg border border-[#475569] bg-[#1e293b] shadow-xl py-1"
            style={{ top: contextMenu.y, left: contextMenu.x }}
            onClick={(e) => e.stopPropagation()}
          >
            <button
              onClick={() => {
                onRefreshSingle(contextMenu.market);
                setContextMenu(null);
              }}
              disabled={scanningIds.has(contextMenu.market.id)}
              className="flex items-center gap-2 w-full px-3 py-2 text-xs text-[#f1f5f9] hover:bg-[#334155] transition-colors disabled:opacity-50"
            >
              {scanningIds.has(contextMenu.market.id) ? (
                <Loader2 className="w-3.5 h-3.5 animate-spin" />
              ) : (
                <RefreshCw className="w-3.5 h-3.5" />
              )}
              Refresh prices
            </button>
            <button
              onClick={() => {
                onDeleteMarket(contextMenu.market.id);
                setContextMenu(null);
              }}
              className="flex items-center gap-2 w-full px-3 py-2 text-xs text-[#ef4444] hover:bg-[#ef4444]/10 transition-colors"
            >
              <Trash2 className="w-3.5 h-3.5" />
              Delete market
            </button>
          </div>
        )}
      </div>
    ) : (
      <div className="flex flex-col items-center py-3 gap-3 h-full">
        <button
          onClick={() => setSidebarOpen(true)}
          className="p-2 rounded-md hover:bg-[#334155] text-[#94a3b8] hover:text-[#f1f5f9] transition-colors"
          title="Expand sidebar"
        >
          <PanelLeftOpen className="w-5 h-5" />
        </button>
        <div className="flex-1 overflow-y-auto w-full flex flex-col items-center gap-2 min-h-0">
          {filtered.slice(0, 30).map((m) => (
            <button
              key={m.id}
              onClick={() => onSelectMarket(m)}
              className={`p-1.5 rounded-md transition-colors ${activeId === m.id ? "bg-[#10b981]/20 text-[#10b981]" : "text-[#94a3b8] hover:bg-[#334155] hover:text-[#f1f5f9]"}`}
              title={`${m.eventTitle}${timeUntilExpiry(m.expiryDate) ? ` \u2022 ${timeUntilExpiry(m.expiryDate)}` : ""}`}
            >
              <Star className={`w-4 h-4 ${favoriteIds.has(m.id) ? "fill-[#f59e0b] text-[#f59e0b]" : ""}`} />
            </button>
          ))}
        </div>
      </div>
    )}
    </aside>
  );
}

/* ── Strategy Badge ── */
function StrategyBadge({ strategy }: { strategy: string }) {
  if (!strategy || strategy === "No arb" || strategy === "—") {
    return <span className="text-[#94a3b8]">—</span>;
  }
  // Parse strategy text like "Buy YES PM + NO Kalshi" or "Buy YES Kalshi + NO PM"
  const parts = strategy.split(/\s*\+\s*/);
  if (parts.length !== 2) {
    return <span className="text-[#64748b] text-xs">{strategy}</span>;
  }
  const parseSide = (part: string) => {
    const isBuy = part.includes("Buy");
    const isYes = part.includes("YES");
    const isNo = part.includes("NO");
    const isKalshi = part.includes("Kalshi");
    const isPm = part.includes("PM");
    return { isBuy, isYes, isNo, isKalshi, isPm };
  };
  const side1 = parseSide(parts[0]);
  const side2 = parseSide(parts[1]);
  return (
    <div className="inline-flex items-center gap-1.5 text-xs">
      <span className="inline-flex items-center gap-0.5">
        {side1.isPm && (
          <span className="inline-flex items-center justify-center w-3.5 h-3.5 rounded-sm bg-[#8b5cf6] text-white text-[8px] font-bold">P</span>
        )}
        {side1.isKalshi && (
          <span className="inline-flex items-center justify-center w-3.5 h-3.5 rounded-sm bg-[#10b981] text-black text-[8px] font-bold">K</span>
        )}
        <span className={`font-bold ${side1.isYes ? "text-[#10b981]" : "text-[#ef4444]"}`}>{side1.isYes ? "YES" : "NO"}</span>
      </span>
      <span className="text-[#525252]">+</span>
      <span className="inline-flex items-center gap-0.5">
        {side2.isPm && (
          <span className="inline-flex items-center justify-center w-3.5 h-3.5 rounded-sm bg-[#8b5cf6] text-white text-[8px] font-bold">P</span>
        )}
        {side2.isKalshi && (
          <span className="inline-flex items-center justify-center w-3.5 h-3.5 rounded-sm bg-[#10b981] text-black text-[8px] font-bold">K</span>
        )}
        <span className={`font-bold ${side2.isYes ? "text-[#10b981]" : "text-[#ef4444]"}`}>{side2.isYes ? "YES" : "NO"}</span>
      </span>
    </div>
  );
}

/* ── Dashboard Panel ── */
function DashboardPanel({ markets }: { markets: SavedMarket[] }) {
  const totalProfit = getTotalProfitAll(markets);
  const weightedAPY = getWeightedAPY(markets);
  const activeMarkets = markets.length;
  const totalArbs = getTotalArbs(markets);
  const hasArb = (m: SavedMarket) => {
    const roi = m.liveResult?.bestRoiPct ?? m.lastScanResult?.bestRoiPct ?? 0;
    const profit = m.liveResult?.bestProfit ?? m.lastScanResult?.bestProfit ?? 0;
    return roi > 0 || profit > 0;
  };
  const arbMarkets = markets.filter(hasArb);
  const avgRoi = arbMarkets.length > 0
    ? arbMarkets.reduce((sum, m) => sum + (m.liveResult?.bestRoiPct ?? m.lastScanResult?.bestRoiPct ?? 0), 0) / arbMarkets.length
    : 0;
  const bestMarket = arbMarkets.length > 0
    ? arbMarkets.reduce((best, m) => {
        const roi = m.liveResult?.bestRoiPct ?? m.lastScanResult?.bestRoiPct ?? 0;
        return roi > (best.liveResult?.bestRoiPct ?? best.lastScanResult?.bestRoiPct ?? 0) ? m : best;
      })
    : null;
  const bestRoi = bestMarket ? (bestMarket.liveResult?.bestRoiPct ?? bestMarket.lastScanResult?.bestRoiPct ?? 0) : 0;
  const bestProfit = bestMarket ? (bestMarket.liveResult?.bestProfit ?? bestMarket.lastScanResult?.bestProfit ?? 0) : 0;

  // Arbitrage Pulse score: 0-100 based on opportunities vs markets
  const pulseScore = markets.length > 0 ? Math.round((arbMarkets.length / markets.length) * 100) : 0;
  const pulseColor = pulseScore >= 30 ? "green" : pulseScore >= 10 ? "yellow" : "red";
