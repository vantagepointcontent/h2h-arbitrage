            <div>
              <label className="text-xs text-[#94a3b8] block mb-1">Category</label>
              <input type="text" value={editCategory} onChange={(e) => setEditCategory(e.target.value)} className="w-full px-3 py-2 rounded-lg bg-[#334155] border border-[#475569] text-sm text-[#f1f5f9] focus:outline-none focus:border-[#10b981]" placeholder="e.g. Politics, Crypto..." />
            </div>
            <div>
              <label className="text-xs text-[#94a3b8] block mb-1">Expiry date</label>
              <input type="date" value={editExpiry} onChange={(e) => setEditExpiry(e.target.value)} className="w-full px-3 py-2 rounded-lg bg-[#334155] border border-[#475569] text-sm text-[#f1f5f9] focus:outline-none focus:border-[#10b981]" />
            </div>
            <div className="flex justify-end gap-2 pt-2">
              <button onClick={() => setEditModalOpen(false)} className="px-4 py-2 rounded-lg bg-[#334155] text-sm hover:bg-[#475569] transition-colors">Cancel</button>
              <button onClick={saveEdit} disabled={saving} className="px-4 py-2 rounded-lg bg-[#10b981] text-black text-sm font-semibold hover:bg-[#16a34a] transition-colors disabled:opacity-50">
