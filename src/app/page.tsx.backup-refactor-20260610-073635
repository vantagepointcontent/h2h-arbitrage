      const res = await fetch("/api/scan", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ kalshiUrl: kUrl, polymarketUrl: pUrl, capital: capital }),
      });
      const data = await res.json();
      if (res.ok) {
        const normalizedData = {
          ...data,
          allOutcomes: data.allOutcomes ?? data.outcomes ?? [],
          outcomes: data.outcomes ?? data.allOutcomes ?? [],
          unmatchedKalshi: (data.unmatchedKalshi ?? []).map((k: UnmatchedKalshi) => ({
            ...k,
            yesAsk: k.yesPrice ?? 0,
            noAsk: k.noPrice ?? 0,
          })),
          unmatchedPolymarket: data.unmatchedPolymarket ?? [],
        };
        setResult(normalizedData);
        setLastUpdated(new Date());
        setLastScanTime(Date.now());
        // Trigger embedded panel refresh on new scan
        setEmbedRefreshCounter((c) => c + 1);
        // Detect price changes
        const changes = new Map<string, "up" | "down" | null>();
        const prices = new Map<string, { kYes: number; pYes: number }>();
        normalizedData.allOutcomes.forEach((o: UnifiedOutcome) => {
          if (o.kalshi && o.polymarket) {
            prices.set(o.artist, { kYes: o.kalshi.yesAsk, pYes: o.polymarket.yesPrice });
            const old = oldPrices.get(o.artist);
            if (old) {
              const kDiff = o.kalshi.yesAsk - old.kYes;
              const pDiff = o.polymarket.yesPrice - old.pYes;
              // Only register if significant change (>0.01)
              if (Math.abs(kDiff) > 0.01 || Math.abs(pDiff) > 0.01) {
                const avgDiff = (kDiff + pDiff) / 2;
                changes.set(o.artist, avgDiff > 0 ? "up" : "down");
              } else {
                changes.set(o.artist, null);
              }
            } else {
              changes.set(o.artist, null);
            }
          }
        });
        setPriceChanges(changes);
        previousPricesRef.current = prices;

        // Update savedMarkets with live result
        const bestArb = (normalizedData.allOutcomes ?? [])
          .map((o: any) => o.arbitrage)
          .filter((a: any) => a && a.roiPct > 0)
          .sort((a: any, b: any) => b.roiPct - a.roiPct)[0];
        if (bestArb && activeMarketIdRef.current) {
          setSavedMarkets(prev => prev.map(m => {
            if (m.id !== activeMarketIdRef.current) return m;
            return {
              ...m,
              liveResult: {
                bestRoiPct: bestArb.roiPct ?? 0,
                bestProfit: bestArb.expectedProfit ?? 0,
                bestApyPct: calculateAPY(bestArb.roiPct ?? 0, m.expiryDate),
                strategy: bestArb.strategy || "",
                scannedAt: new Date().toISOString(),
                allArbs: (normalizedData.allOutcomes ?? [])
                  .filter((o: any) => o.arbitrage && o.arbitrage.roiPct > 0)
                  .map((o: any) => ({
                    artist: o.artist,
                    roiPct: o.arbitrage.roiPct,
                    expectedProfit: o.arbitrage.expectedProfit,
                    strategy: o.arbitrage.strategy,
                    totalStake: o.arbitrage.totalStake,
                  })),
              },
            };
          }));
        }
      } else {
        setError(data.error || "Scan failed");
      }
    } catch (err: any) {
      setError(err.message || "Network error");
    } finally {
      setLoading(false);
    }
  }, []);

  // Saved markets
  const loadSavedMarkets = useCallback(async (): Promise<SavedMarket[]> => {
    try {
      const res = await fetch("/api/saved-markets");
      if (res.ok) {
        const data = await res.json();
        setSavedMarkets(data.markets || []);
        return data.markets || [];
      }
    } catch { /* ignore */ }
    return [];
  }, []);

  const refreshOverview = useCallback(() => {
    setOverviewLoading(true);
    loadSavedMarkets().finally(() => setOverviewLoading(false));
  }, [loadSavedMarkets]);

  const loadManualMatches = async () => {
    try {
      const res = await fetch("/api/manual-matches");
      if (res.ok) {
        const data = await res.json();
        setManualMatches(data.matches || []);
      }
    } catch { /* ignore */ }
  };

  // Scan ALL saved markets with LIVE prices
  const scanAllMarkets = async () => {
    if (scanningAll) return;
    setScanningAll(true);
    setScanAllError("");
    const failed: string[] = [];
    const refreshed: { id: string; result: any }[] = [];

    for (const market of savedMarketsRef.current) {
      try {
        const res = await fetch(`/api/scan`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            kalshiUrl: market.kalshiUrl,
            polymarketUrl: market.polymarketUrl,
            capital: capital,
          }),
        });
        if (res.ok) {
          const data = await res.json();
          refreshed.push({ id: market.id, result: data });
        } else {
          failed.push(market.eventTitle);
        }
      } catch {
        failed.push(market.eventTitle);
      }
    }

    setSavedMarkets(prev => prev.map(m => {
      const r = refreshed.find(x => x.id === m.id);
      if (!r) return m;
      const bestArb = (r.result.allOutcomes ?? r.result.outcomes ?? [])
        .map((o: any) => o.arbitrage)
        .filter((a: any) => a && a.roiPct > 0)
        .sort((a: any, b: any) => b.roiPct - a.roiPct)[0];
      return {
        ...m,
        liveResult: {
          bestRoiPct: bestArb?.roiPct ?? 0,
          bestProfit: bestArb?.expectedProfit ?? 0,
          bestApyPct: calculateAPY(bestArb?.roiPct ?? 0, m.expiryDate),
          strategy: bestArb?.strategy || "",
          scannedAt: new Date().toISOString(),
          allArbs: (r.result.allOutcomes ?? r.result.outcomes ?? [])
            .filter((o: any) => o.arbitrage && o.arbitrage.roiPct > 0)
            .map((o: any) => ({
              artist: o.artist,
              roiPct: o.arbitrage.roiPct,
              expectedProfit: o.arbitrage.expectedProfit,
              strategy: o.arbitrage.strategy,
              totalStake: o.arbitrage.totalStake,
            })),
        },
      };
    }));

    for (const r of refreshed) {
      const market = savedMarketsRef.current.find(m => m.id === r.id);
      if (market && r.result.bestRoiPct > 0) {
        alertSystem.checkAndFire(
          market.eventTitle,
          market.id,
          r.result.bestRoiPct,
          r.result.strategy || "",
          r.result.bestProfit ?? 0,
        );
      }
    }

    setScanningAll(false);
    if (failed.length > 0) {
      setScanAllError(`${failed.length} market${failed.length > 1 ? "s" : ""} failed to refresh`);
    }
  };

  // Delete saved market
  const deleteMarket = async (id: string) => {
    try {
      const res = await fetch(`/api/saved-markets/${id}`, { method: "DELETE" });
      if (res.ok) {
        await loadSavedMarkets();
        if (activeMarketId === id) {
