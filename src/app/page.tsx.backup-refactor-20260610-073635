/* ── Overview Panel ── */
function OverviewPanel({
  markets,
  loading,
  onLoad,
  sort,
  sortDir,
  onToggleSort,
  layout,
  onToggleLayout,
  expiryFilter,
  onSetExpiryFilter,
  timeUntilExpiry,
  formatExpiry,
  onOpenMarket,
  favoriteIds,
  onToggleFavorite,
  showFavoritesOnly,
  onToggleFavoritesOnly,
}: {
  markets: SavedMarket[];
  loading: boolean;
  onLoad: () => void;
  sort: OverviewSort;
  sortDir: "asc" | "desc";
  onToggleSort: (f: OverviewSort) => void;
  layout: "grid" | "table";
  onToggleLayout: (l: "grid" | "table") => void;
  expiryFilter: "all" | "lte7" | "lte14" | "lte30";
  onSetExpiryFilter: (f: "all" | "lte7" | "lte14" | "lte30") => void;
  timeUntilExpiry: (iso?: string | null) => string;
  formatExpiry: (iso?: string | null) => string;
  onOpenMarket: (m: SavedMarket) => void;
  favoriteIds: Set<string>;
  onToggleFavorite: (id: string) => void;
  showFavoritesOnly: boolean;
  onToggleFavoritesOnly: () => void;
}) {
  const [showArbOnly, setShowArbOnly] = useState(true);
  useEffect(() => { onLoad(); }, [onLoad]);

  const hasArb = (m: SavedMarket) => {
    const roi = m.liveResult?.bestRoiPct ?? m.lastScanResult?.bestRoiPct ?? 0;
    const profit = m.liveResult?.bestProfit ?? m.lastScanResult?.bestProfit ?? 0;
    return roi > 0 || profit > 0;
  };

  const daysToExpiry = (iso?: string | null): number => {
    if (!iso) return Infinity;
    return Math.floor((parseDateToUTC(iso) - Date.now()) / 86400000);
  };

  const sortFn = (a: SavedMarket, b: SavedMarket) => {
    const mul = sortDir === "asc" ? 1 : -1;
    if (sort === "name") return mul * a.eventTitle.localeCompare(b.eventTitle);
    if (sort === "expiry") {
      const ea = a.expiryDate ? new Date(a.expiryDate).getTime() : Infinity;
      const eb = b.expiryDate ? new Date(b.expiryDate).getTime() : Infinity;
      return mul * (ea - eb);
    }
    if (sort === "roi") {
      const ra = a.liveResult?.bestRoiPct ?? a.lastScanResult?.bestRoiPct ?? 0;
      const rb = b.liveResult?.bestRoiPct ?? b.lastScanResult?.bestRoiPct ?? 0;
      return mul * (rb - ra);
    }
    if (sort === "apy") {
      const ra = a.liveResult?.bestRoiPct ?? a.lastScanResult?.bestRoiPct ?? 0;
      const rb = b.liveResult?.bestRoiPct ?? b.lastScanResult?.bestRoiPct ?? 0;
      const aa = calculateAPY(ra, a.expiryDate);
      const ab = calculateAPY(rb, b.expiryDate);
      return mul * (ab - aa);
    }
    if (sort === "profit") {
      const pa = a.liveResult?.bestProfit ?? a.lastScanResult?.bestProfit ?? 0;
      const pb = b.liveResult?.bestProfit ?? b.lastScanResult?.bestProfit ?? 0;
      return mul * (pb - pa);
    }
    return 0;
  };

  const filtered = markets.filter(m => {
    if (showFavoritesOnly && !favoriteIds.has(m.id)) return false;
    if (showArbOnly && !hasArb(m)) return false;
    if (expiryFilter !== "all") {
      const days = daysToExpiry(m.expiryDate);
      if (expiryFilter === "lte7" && days > 7) return false;
      if (expiryFilter === "lte14" && days > 14) return false;
      if (expiryFilter === "lte30" && days > 30) return false;
    }
    return true;
  }).sort(sortFn);

  const SortHeader = ({ field, label, align = "left" }: { field: OverviewSort; label: string; align?: "left" | "right" }) => (
    <th
      onClick={() => onToggleSort(field)}
      className={`px-4 py-3 font-medium cursor-pointer hover:text-[#f1f5f9] transition-colors select-none ${align === "right" ? "text-right" : "text-left"}`}
    >
      <span className="inline-flex items-center gap-1">
        {label}
        {sort === field && (
          sortDir === "asc" ? <ArrowUp className="w-3 h-3" /> : <ArrowDown className="w-3 h-3" />
        )}
      </span>
    </th>
  );

  return (
    <div className="space-y-5">
      {/* Key value stat boxes */}
      {filtered.length > 0 && (
        <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
          <StatCard
            label="Total Profit"
            value={formatCurrency(getTotalProfitAll(filtered))}
            icon={<TrendingUp className="w-4 h-4" />}
            color="green"
          />
          <StatCard
            label="Weighted APY"
            value={`${getWeightedAPY(filtered).toFixed(1)}%`}
            icon={<Percent className="w-4 h-4" />}
            color="blue"
          />
          <StatCard
            label="Active Markets"
            value={filtered.length}
            icon={<Activity className="w-4 h-4" />}
            color="purple"
          />
          <StatCard
            label="Total Arb Opportunities"
            value={getTotalArbs(filtered)}
            icon={<Link2 className="w-4 h-4" />}
            color="yellow"
          />
        </div>
      )}

      <div className="flex items-center justify-between">
        <h2 className="text-xl font-bold tracking-tight">Overview</h2>
        <div className="flex items-center gap-2">
          {/* Expiry filter buttons (replaced sort buttons) */}
          <div className="flex items-center gap-0.5 rounded-lg bg-[#334155] border border-[#475569] overflow-hidden">
            {(["all", "lte7", "lte14", "lte30"] as const).map((f) => (
              <button
                key={f}
                onClick={() => onSetExpiryFilter(f === expiryFilter ? "all" : f)}
                className={`px-2.5 py-1.5 text-[10px] font-medium transition-colors ${
                  expiryFilter === f
                    ? "bg-[#10b981]/10 text-[#10b981]"
                    : "text-[#94a3b8] hover:text-[#f1f5f9]"
                }`}
              >
                {f === "all" ? "All" : f === "lte7" ? "7d" : f === "lte14" ? "14d" : "30d"}
              </button>
            ))}
          </div>
          {/* Arb only toggle */}
          <button
            onClick={() => setShowArbOnly(v => !v)}
            className={`px-2.5 py-1.5 rounded-lg text-[10px] font-medium transition-colors ${
              showArbOnly
                ? "bg-[#10b981]/10 text-[#10b981]"
                : "bg-[#334155] text-[#94a3b8] hover:text-[#f1f5f9]"
            }`}
            title="Show only markets with arbitrage"
          >
            Arb only
          </button>
          {/* Favorites toggle */}
          <button
            onClick={onToggleFavoritesOnly}
            className={`px-2.5 py-1.5 rounded-lg text-[10px] font-medium transition-colors flex items-center gap-1 ${
              showFavoritesOnly
                ? "bg-[#f59e0b]/10 text-[#f59e0b]"
                : "bg-[#334155] text-[#94a3b8] hover:text-[#f59e0b]"
            }`}
            title="Show only favorites"
          >
            <Star className={`w-3 h-3 ${showFavoritesOnly ? "fill-current" : ""}`} />
            Favs
          </button>
          <button onClick={() => onToggleLayout(layout === "grid" ? "table" : "grid")} className="p-2 rounded-lg bg-[#334155] hover:bg-[#475569] text-[#94a3b8] transition-colors" title="Toggle layout">
            {layout === "grid" ? <Rows3 className="w-4 h-4" /> : <LayoutGrid className="w-4 h-4" />}
          </button>
        </div>
      </div>

      {loading ? (
        <div className="py-20 text-center text-sm text-[#94a3b8]">
          <Loader2 className="w-6 h-6 animate-spin mx-auto mb-3" />
          Loading markets...
        </div>
      ) : filtered.length === 0 ? (
        <div className="py-20 text-center text-sm text-[#525252]">
          No saved markets match filters.
        </div>
      ) : layout === "grid" ? (
        <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
          {filtered.map((m) => {
            const roi = m.liveResult?.bestRoiPct ?? m.lastScanResult?.bestRoiPct ?? 0;
            const profit = m.liveResult?.bestProfit ?? m.lastScanResult?.bestProfit ?? 0;
            const allArbs = m.liveResult?.allArbs ?? m.lastScanResult?.allArbs;
            const isFav = favoriteIds.has(m.id);
            return (
              <div
                key={m.id}
                role="button"
                tabIndex={0}
                onClick={() => onOpenMarket(m)}
                onKeyDown={(e) => {
                  if (e.key === "Enter" || e.key === " ") {
                    e.preventDefault();
                    onOpenMarket(m);
                  }
                }}
                className="rounded-xl border border-[#334155] bg-[#1e293b] p-4 space-y-3 cursor-pointer hover:border-[#10b981]/40 hover:bg-[#1e293b] transition-colors"
              >
                <div className="flex items-start justify-between">
                  <h3 className="font-semibold text-sm text-[#f1f5f9]">{m.eventTitle}</h3>
                  <div className="flex items-center gap-1">
                    <button
                      onClick={(e) => {
                        e.stopPropagation();
                        onToggleFavorite(m.id);
                      }}
                      className={`p-1 rounded transition-colors ${isFav ? "text-[#f59e0b]" : "text-[#525252] hover:text-[#f59e0b]"}`}
                    >
                      <Star className={`w-3.5 h-3.5 ${isFav ? "fill-current" : ""}`} />
                    </button>
                    {m.category && <span className="text-[10px] px-1.5 py-0.5 rounded-full bg-[#334155] text-[#94a3b8]">{m.category}</span>}
                  </div>
                </div>
                <div className="grid grid-cols-2 gap-2 text-xs">
                  <div className="text-[#94a3b8]">Expiry</div>
                  <div className="text-[#f1f5f9] text-right">{formatExpiry(m.expiryDate)}</div>
                  <div className="text-[#94a3b8]">Best ROI</div>
                  <div className={`text-right font-bold ${roi > 0 ? "text-[#10b981]" : roi < 0 ? "text-[#ef4444]" : "text-[#94a3b8]"}`}>
                    {roi !== 0 ? `${roi > 0 ? "+" : ""}${formatPercent(roi)}` : "—"}
                  </div>
                  <div className="text-[#94a3b8]">APY</div>
                  <div className={`text-right font-bold ${calculateAPY(roi, m.expiryDate) > 0 ? "text-[#3b82f6]" : "text-[#94a3b8]"}`}>
                    {roi !== 0 ? `${calculateAPY(roi, m.expiryDate).toFixed(1)}%` : "—"}
                  </div>
                  <div className="text-[#94a3b8]">Est. Profit</div>
                  <div className="text-[#f1f5f9] text-right">{profit !== 0 ? formatProfitDisplay(profit, allArbs) : "—"}</div>
                </div>
                <div className="flex items-center gap-1 text-[10px] text-[#525252]">
                  <Clock className="w-3 h-3" />
                  {timeUntilExpiry(m.expiryDate)}
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div className="rounded-xl border border-[#334155] bg-[#1e293b] overflow-hidden">
          <table className="w-full text-sm">
            <thead className="bg-[#1e293b] border-b border-[#334155]">
              <tr className="text-[10px] text-[#94a3b8] uppercase tracking-wider">
                <SortHeader field="name" label="Market" />
                <SortHeader field="expiry" label="Expiry" align="right" />
                <SortHeader field="roi" label="ROI" align="right" />
                <SortHeader field="apy" label="APY" align="right" />
                <SortHeader field="profit" label="Profit" align="right" />
                <th className="text-left px-4 py-3 font-medium">Strategy</th>
                <th className="text-center px-4 py-3 font-medium">Fav</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-[#334155]">
              {filtered.map((m) => {
                const roi = m.liveResult?.bestRoiPct ?? m.lastScanResult?.bestRoiPct ?? 0;
                const profit = m.liveResult?.bestProfit ?? m.lastScanResult?.bestProfit ?? 0;
                const allArbs = m.liveResult?.allArbs ?? m.lastScanResult?.allArbs;
                const strategy = m.liveResult?.strategy ?? m.lastScanResult?.strategy ?? "";
                const apy = calculateAPY(roi, m.expiryDate);
                const isFav = favoriteIds.has(m.id);
                return (
                  <tr
                    key={m.id}
                    onClick={() => onOpenMarket(m)}
                    className="hover:bg-[#334155]/50 transition-colors cursor-pointer"
                  >
                    <td className="px-4 py-3 font-medium text-[#f1f5f9]">{m.eventTitle}</td>
                    <td className="px-4 py-3 text-right text-[#f1f5f9]">{formatExpiry(m.expiryDate)}</td>
                    <td className={`px-4 py-3 text-right font-bold ${roi > 0 ? "text-[#10b981]" : roi < 0 ? "text-[#ef4444]" : "text-[#94a3b8]"}`}>
                      {roi !== 0 ? `${roi > 0 ? "+" : ""}${formatPercent(roi)}` : "—"}
                    </td>
                    <td className={`px-4 py-3 text-right font-bold ${apy > 0 ? "text-[#3b82f6]" : "text-[#94a3b8]"}`}>
                      {roi !== 0 ? `${apy.toFixed(1)}%` : "—"}
